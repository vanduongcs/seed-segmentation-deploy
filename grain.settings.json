{
  "pipeline": "yolo8_nano_segment_deploy",
  "params": {
    "maxSide": { "type": "number", "default": 768, "min": 128, "max": 1024 },
    "yoloModelPath": { "type": "string", "default": "auto", "env": "GRAIN_YOLO_MODEL" },
    "yoloConf": { "type": "number", "default": 0.25, "min": 0.05, "max": 0.99 },
    "yoloIou": { "type": "number", "default": 0.60, "min": 0.05, "max": 0.95 },
    "yoloMaxDet": { "type": "number", "default": 300, "min": 1, "max": 300 },
    "enableTiledInference": { "type": "boolean", "default": false },
    "enableFullImagePass": { "type": "boolean", "default": true },
    "tileSize": { "type": "number", "default": 768, "min": 160, "max": 1024 },
    "tileOverlap": { "type": "number", "default": 0.20, "min": 0, "max": 0.8 },
    "enableTinyTilePass": { "type": "boolean", "default": false },
    "tinyTileSize": { "type": "number", "default": 320, "min": 160, "max": 1024 },
    "mergeIou": { "type": "number", "default": 0.35, "min": 0.05, "max": 0.95 },
    "mergeOverlap": { "type": "number", "default": 0.70, "min": 0.05, "max": 1.0 },
    "edgeMarginRatio": { "type": "number", "default": 0.1, "min": 0, "max": 0.4 },
    "enableSamRefine": { "type": "boolean", "default": false },
    "samModel": { "type": "string", "default": "FastSAM-s.onnx", "env": "GRAIN_SAM_MODEL" },
    "samCandidateLimit": { "type": "number", "default": 80, "min": 1, "max": 300 },
    "samBoxPadding": { "type": "number", "default": 8, "min": 0, "max": 128 },
    "samConf": { "type": "number", "default": 0.25, "min": 0.01, "max": 0.99 },
    "samIou": { "type": "number", "default": 0.90, "min": 0.05, "max": 0.99 },
    "samMaxDet": { "type": "number", "default": 100, "min": 1, "max": 300 },
    "enableGrabCut": { "type": "boolean", "default": false },
    "grabCutIter": { "type": "number", "default": 2, "min": 1, "max": 5 },
    "enableEdgeSnap": { "type": "boolean", "default": false },
    "edgeSnapRadius": { "type": "number", "default": 4, "min": 1, "max": 12 },
    "edgeSnapSigma": { "type": "number", "default": 1.2, "min": 0.5, "max": 5.0 },
    "maskContourSmooth": { "type": "number", "default": 0.8, "min": 0, "max": 3 },
    "preprocessImage": { "type": "boolean", "default": false },
    "whiteBalanceStrength": { "type": "number", "default": 0.25, "min": 0, "max": 1 },
    "claheClipLimit": { "type": "number", "default": 2.5, "min": 0, "max": 6 },
    "claheTileSize": { "type": "number", "default": 5, "min": 2, "max": 32 },
    "denoiseStrength": { "type": "number", "default": 0.1, "min": 0, "max": 1 },
    "denoiseDiameter": { "type": "number", "default": 5, "min": 3, "max": 15 },
    "minArea": { "type": "number", "default": 12, "min": 1, "max": 1000000 },
    "maxArea": { "type": "number", "default": 200000, "min": 1, "max": 100000000 },
    "maxSegmentAspectRatio": { "type": "number", "default": 20, "min": 1, "max": 200 },
    "minSegmentSolidity": { "type": "number", "default": 0.4, "min": 0, "max": 1 },
    "minSegmentExtent": { "type": "number", "default": 0.15, "min": 0, "max": 1 },
    "referencePixels": { "type": "number", "default": 0, "min": 0, "max": 1000000 },
    "referenceMm": { "type": "number", "default": 0, "min": 0, "max": 1000000 },
    "referencePixelSpace": { "type": "string", "default": "original" }
  },
  "csvColumns": [
    "id", "area_px", "length_px", "width_px",
    "area_mm2", "length_mm", "width_mm",
    "centroid_x", "centroid_y",
    "bbox_x", "bbox_y", "bbox_w", "bbox_h",
    "angle_deg", "solidity", "extent", "aspect_ratio",
    "confidence", "class_id", "class_name"
  ],
  "palette": [
    [45, 108, 191],
    [219, 87, 86],
    [73, 160, 120],
    [235, 174, 73],
    [132, 98, 174],
    [77, 176, 196],
    [201, 112, 165],
    [122, 126, 135]
  ]
}
